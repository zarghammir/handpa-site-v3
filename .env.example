# Supabase — https://supabase.com/dashboard/project/<your-project>/settings/api
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# Supabase service role (server-side only — never expose to the browser)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Mapbox — https://account.mapbox.com/access-tokens/
VITE_MAPBOX_TOKEN=pk.your_mapbox_token_here

# Resend — https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key_here

# Cal.com webhook secret — https://cal.com/settings/developer/webhooks
CAL_WEBHOOK_SECRET=your_cal_webhook_secret_here

# Your production site URL (used for approval links in emails)
SITE_URL=https://your-site.vercel.app
